---
import { env } from "cloudflare:workers";
import Layout from "../layouts/Layout.astro";
import Calendar from "../components/Calendar.astro";
import {
    buildMonthGrid,
    parseMonthParam,
    prevMonth,
    nextMonth,
    monthKey,
    formatMonthLabel,
    todayISO,
    currentMonth,
    isValidDateISO,
} from "../lib/dates";
import { listEntriesForMonth } from "../lib/entries";
import { getSetting } from "../lib/settings";
import Countdown from "../components/Countdown.astro";

const timezone = env.APP_TIMEZONE ?? "UTC";
const db = env.DB;

const todayStr = todayISO(timezone);

// Determine which month to display (?month=YYYY-MM, defaulting to current)
const requested = parseMonthParam(
    Astro.url.searchParams.get("month") ?? undefined,
);
const { year, month } = requested ?? currentMonth(timezone);

const cells = buildMonthGrid(year, month, todayStr);
const entries = await listEntriesForMonth(db, year, month);

const prev = prevMonth(year, month);
const next = nextMonth(year, month);

// Homepage countdown deadline (from the settings table). Validated in case
// of legacy/corrupt data; invalid values are treated as "not set".
const rawDeadline = await getSetting(db, "deadline");
const deadline = rawDeadline && isValidDateISO(rawDeadline) ? rawDeadline : null;
---

<Layout title="sprout">
    <div class="space-y-5">
        <!-- Countdown to the configured deadline (hidden when none set) -->
        <Countdown deadline={deadline} timezone={timezone} />

        <!-- Month navigation -->
        <div class="flex items-center justify-between">
            <a
                href={`/?month=${monthKey(prev.year, prev.month)}`}
                class="flex h-9 w-9 items-center justify-center rounded-lg text-ink-soft transition-colors hover:bg-surface hover:text-accent"
                aria-label="Previous month"
            >
                ‹
            </a>
            <h1 class="text-lg font-semibold text-ink">
                {formatMonthLabel(year, month)}
            </h1>
            <a
                href={`/?month=${monthKey(next.year, next.month)}`}
                class="flex h-9 w-9 items-center justify-center rounded-lg text-ink-soft transition-colors hover:bg-surface hover:text-accent"
                aria-label="Next month"
            >
                ›
            </a>
        </div>

        <Calendar cells={cells} entries={entries} />

        <!-- Subtle hint -->
        <p class="pt-2 text-center text-xs text-ink-soft">Stay Focused ♥</p>
        <a
            href="/config"
            class="block text-center text-xs text-ink-soft transition-colors hover:text-accent"
        >
            config
        </a>
    </div>
</Layout>
