---
import type { Entry } from '../lib/entries';
import { formatLongDate } from '../lib/dates';
import RatingDots from './RatingDots.astro';

/**
 * Read-only view of a single past entry — the date, the 1–5 rating,
 * and the full journal text. Past entries are immutable.
 */
interface Props {
	entry: Entry;
}

const { entry } = Astro.props;
---

<article class="space-y-6">
	<div class="flex items-center justify-between gap-4">
		<h1 class="text-xl font-semibold text-ink">{formatLongDate(entry.date)}</h1>
		<RatingDots rating={entry.rating} />
	</div>
	<div class="whitespace-pre-wrap text-base leading-relaxed text-ink">
		{entry.content}
	</div>
</article>
